{
  "version": "1.0",
  "version_name": "WBTI·Red v1.0",
  "main": [
    { "id": 1,  "order": 1,  "pole": "T", "text": "喝完一口红酒，你嘴巴里最明显的感受是？", "options": { "A": "咬舌、发涩，舌头有点干", "B": "有点感觉，但说不上涩", "C": "很顺滑，完全不涩" } },
    { "id": 2,  "order": 2,  "pole": "S", "text": "如果用水果形容红酒，你更想要的是？", "options": { "A": "果酱、黑莓、甜腻", "B": "混合水果", "C": "新鲜草莓、樱桃，水汪汪" } },
    { "id": 3,  "order": 3,  "pole": "T", "text": "配主菜的话，你第一反应是？", "options": { "A": "战斧牛排、炖肉、烧烤", "B": "什么都行", "C": "白肉、淡菜、寿司" } },
    { "id": 4,  "order": 4,  "pole": "S", "text": "你的饮用习惯更接近？", "options": { "A": "一个人慢慢喝，配个电影", "B": "看心情", "C": "一桌人干杯畅饮" } },
    { "id": 5,  "order": 5,  "pole": "T", "text": "看酒的颜色，你更偏好？", "options": { "A": "深紫黑，几乎不透光", "B": "深宝石红", "C": "清澈宝石红，能看穿杯子" } },
    { "id": 6,  "order": 6,  "pole": "S", "text": "你喝酒后舌头的着色程度？", "options": { "A": "牙齿挂紫，舌头染色", "B": "一点点", "C": "基本不染色" } },
    { "id": 7,  "order": 7,  "pole": "T", "text": "如果把酒比作音乐，你更想要？", "options": { "A": "重鼓、贝斯、摇滚", "B": "流行", "C": "民谣、钢琴、轻盈" } },
    { "id": 8,  "order": 8,  "pole": "S", "text": "对『涩』这个字，你的第一反应？", "options": { "A": "怕、单宁一高就皱眉", "B": "无所谓", "C": "欢迎，越涩越带劲" } },

    { "id": 9,  "order": 9,  "pole": "A", "text": "一口下去，你的口水反应？", "options": { "A": "立刻分泌，止不住", "B": "有一点", "C": "基本不流口水" } },
    { "id": 10, "order": 10, "pole": "A", "text": "配菜你更想配？", "options": { "A": "酸辣、油醋、海鲜", "B": "随便", "C": "甜点、巧克力、奶酪" } },
    { "id": 11, "order": 11, "pole": "C", "text": "你希望酒入口的感觉？", "options": { "A": "有点尖、有点刺、活泼", "B": "中间", "C": "圆润、顺、温柔" } },
    { "id": 12, "order": 12, "pole": "A", "text": "葡萄品种里你更熟悉的？", "options": { "A": "雷司令、长相思、黑皮诺", "B": "听过一些", "C": "梅洛、歌海娜、霞多丽" } },
    { "id": 13, "order": 13, "pole": "C", "text": "你的甜咸偏好？", "options": { "A": "更爱甜食、奶茶", "B": "看心情", "C": "更爱咸鲜、烧烤" } },
    { "id": 14, "order": 14, "pole": "A", "text": "夏天户外，你会选？", "options": { "A": "冰到 8 度的干白/起泡", "B": "都行", "C": "室温红酒" } },
    { "id": 15, "order": 15, "pole": "C", "text": "朋友形容你的『气场』？", "options": { "A": "有锋芒、有主张", "B": "看场合", "C": "温和、包容、柔" } },
    { "id": 16, "order": 16, "pole": "C", "text": "你喝完酒更想？", "options": { "A": "继续吃点什么、说走就走", "B": "发呆", "C": "窝沙发不动" } },

    { "id": 17, "order": 17, "pole": "F", "text": "挂杯（酒腿）你更想要？", "options": { "A": "缓慢、粘稠、挂满杯", "B": "有就行", "C": "很快流下、清透" } },
    { "id": 18, "order": 18, "pole": "L", "text": "入口的口感你更想要？", "options": { "A": "像喝水一样过嘴", "B": "中间", "C": "包住舌头、有重量" } },
    { "id": 19, "order": 19, "pole": "F", "text": "如果用饮品类比，你更想要？", "options": { "A": "拿铁、奶昔、厚", "B": "柠檬水", "C": "气泡水、清茶" } },
    { "id": 20, "order": 20, "pole": "F", "text": "配菜你更想配？", "options": { "A": "战斧、炖肉、烤鸭", "B": "什么都行", "C": "沙拉、白肉、海鲜" } },
    { "id": 21, "order": 21, "pole": "L", "text": "冬夜独饮你更想？", "options": { "A": "一壶热茶、一杯清酒", "B": "都可以", "C": "一杯饱满的赤霞珠" } },
    { "id": 22, "order": 22, "pole": "F", "text": "酒在你嘴里的『覆盖感』？", "options": { "A": "薄薄一层、一闪而过", "B": "一般", "C": "满满覆盖、压舌" } },
    { "id": 23, "order": 23, "pole": "L", "text": "派对畅饮你更想？", "options": { "A": "清爽、轻盈、不上头", "B": "看场合", "C": "醇厚、有料、慢喝" } },
    { "id": 24, "order": 24, "pole": "L", "text": "如果酒是一个『状态』，你更想要？", "options": { "A": "轻盈、自由、跑起来", "B": "中间", "C": "稳重、踏地、坐得住" } },

    { "id": 25, "order": 25, "pole": "R", "text": "喝完一口，半小时后你嘴里？", "options": { "A": "还在回甘、还有味道", "B": "忘了", "C": "早没了，干干净净" } },
    { "id": 26, "order": 26, "pole": "Q", "text": "你对『快』和『慢』的偏好？", "options": { "A": "喜欢慢节奏、细品", "B": "都行", "C": "喜欢干脆利落、一口完事" } },
    { "id": 27, "order": 27, "pole": "R", "text": "酒越喝你越？", "options": { "A": "越觉得香、有层次", "B": "没感觉", "C": "越来越淡、想换" } },
    { "id": 28, "order": 28, "pole": "Q", "text": "如果酒是一种『风格』，你更想要？", "options": { "A": "复古、复杂、有故事", "B": "都看", "C": "现代、简单、明了" } },
    { "id": 29, "order": 29, "pole": "R", "text": "跟朋友描述一款酒你更强调？", "options": { "A": "回味、余韵、绵长", "B": "都好喝", "C": "入口感、冲击力" } },
    { "id": 30, "order": 30, "pole": "Q", "text": "你喝酒的速度更接近？", "options": { "A": "小口慢呷、停不下来", "B": "看情况", "C": "大杯一口闷掉" } },
    { "id": 31, "order": 31, "pole": "R", "text": "你欣赏一位『老酒客』的原因是？", "options": { "A": "能品出尾韵、说出层次", "B": "都欣赏", "C": "能狂喝、说喝就喝" } },
    { "id": 32, "order": 32, "pole": "Q", "text": "你更讨厌什么？", "options": { "A": "喝完嘴里寡淡、没东西", "B": "看情况", "C": "喝完嘴里一直有东西、不清爽" } }
  ]
}
